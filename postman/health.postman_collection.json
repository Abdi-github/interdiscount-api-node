{
  "info": {
    "name": "Health Module",
    "description": "API health check endpoints for monitoring server, database, Redis, and queue status",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4010/api/v1" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has status ok', () => pm.expect(pm.response.json().data.status).to.eql('ok'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Database Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health/db",
          "host": ["{{base_url}}"],
          "path": ["health", "db"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('DB connected', () => pm.expect(pm.response.json().data.status).to.eql('connected'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Redis Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health/redis",
          "host": ["{{base_url}}"],
          "path": ["health", "redis"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Redis connected', () => pm.expect(pm.response.json().data.status).to.eql('connected'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Queue Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health/queues",
          "host": ["{{base_url}}"],
          "path": ["health", "queues"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    }
  ]
}
