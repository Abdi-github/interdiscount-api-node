          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"password\": \"NewPassword123!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/public/auth/reset-password",
          "host": ["{{base_url}}"],
          "path": ["public", "auth", "reset-password"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 or 400', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Resend Verification",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer.de@example.ch\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/public/auth/resend-verification",
          "host": ["{{base_url}}"],
          "path": ["public", "auth", "resend-verification"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "Validation - Login Missing Password",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer.de@example.ch\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/public/auth/login",
          "host": ["{{base_url}}"],
          "path": ["public", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Has error', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ]
    }
  ]
}
