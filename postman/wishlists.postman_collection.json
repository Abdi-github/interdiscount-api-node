{
  "info": {
    "name": "Wishlists Module",
    "description": "Customer product wishlist: add, remove, list, and check if product is wishlisted",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4010/api/v1" }
  ],
  "item": [
    {
      "name": "Auth - Login as Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success) {",
              "  pm.environment.set('customer_token', res.data.tokens.access_token);",
              "}",
              "pm.test('Login successful', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer.de@example.ch\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/public/auth/login",
          "host": ["{{base_url}}"],
          "path": ["public", "auth", "login"]
        }
      }
    },
    {
      "name": "Wishlist",
      "item": [
        {
          "name": "List My Wishlist",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/wishlist?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["customer", "wishlist"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Add to Wishlist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/wishlist/69a079537808ec1bb791744f",
              "host": ["{{base_url}}"],
              "path": ["customer", "wishlist", "69a079537808ec1bb791744f"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.environment.set('wishlist_product_id', '69a079537808ec1bb791744f');"
                ]
              }
            }
          ]
        },
        {
          "name": "Check if Wishlisted",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/wishlist/check/{{wishlist_product_id}}",
              "host": ["{{base_url}}"],
              "path": ["customer", "wishlist", "check", "{{wishlist_product_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is wishlisted', () => pm.expect(pm.response.json().data.is_wishlisted).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "Remove from Wishlist",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/wishlist/{{wishlist_product_id}}",
              "host": ["{{base_url}}"],
              "path": ["customer", "wishlist", "{{wishlist_product_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 204', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
