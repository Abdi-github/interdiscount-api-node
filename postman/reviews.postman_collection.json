{
  "info": {
    "name": "Reviews Module",
    "description": "Customer product review management: create, list, update, delete reviews",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4010/api/v1" }
  ],
  "item": [
    {
      "name": "Auth - Login as Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success) {",
              "  pm.environment.set('customer_token', res.data.tokens.access_token);",
              "}",
              "pm.test('Login successful', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer.de@example.ch\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/public/auth/login",
          "host": ["{{base_url}}"],
          "path": ["public", "auth", "login"]
        }
      }
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"69a079537808ec1bb7917455\",\n  \"rating\": 5,\n  \"title\": \"Ausgezeichnetes Produkt!\",\n  \"comment\": \"Sehr zufrieden mit der Qualität und dem schnellen Versand. Würde es jederzeit wieder kaufen.\",\n  \"language\": \"de\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/customer/reviews",
              "host": ["{{base_url}}"],
              "path": ["customer", "reviews"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Review created', () => {",
                  "  pm.expect(pm.response.json().data.rating).to.eql(5);",
                  "});",
                  "if (pm.response.json().data) {",
                  "  pm.environment.set('review_id', pm.response.json().data._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List My Reviews",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/reviews?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["customer", "reviews"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"title\": \"Gutes Produkt\",\n  \"comment\": \"Nach einiger Zeit funktioniert alles noch einwandfrei. Solides Gerät.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/customer/reviews/{{review_id}}",
              "host": ["{{base_url}}"],
              "path": ["customer", "reviews", "{{review_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/reviews/{{review_id}}",
              "host": ["{{base_url}}"],
              "path": ["customer", "reviews", "{{review_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 204', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
