{
  "info": {
    "name": "Addresses Module",
    "description": "Customer delivery/billing address management with Swiss postal code validation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4010/api/v1" }
  ],
  "item": [
    {
      "name": "Auth - Login as Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success) {",
              "  pm.environment.set('customer_token', res.data.tokens.access_token);",
              "}",
              "pm.test('Login successful', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer.de@example.ch\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/public/auth/login",
          "host": ["{{base_url}}"],
          "path": ["public", "auth", "login"]
        }
      }
    },
    {
      "name": "Addresses",
      "item": [
        {
          "name": "List My Addresses",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/addresses",
              "host": ["{{base_url}}"],
              "path": ["customer", "addresses"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "if (pm.response.json().data.length > 0) {",
                  "  pm.environment.set('address_id', pm.response.json().data[0]._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Address",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Office\",\n  \"first_name\": \"Max\",\n  \"last_name\": \"Muster\",\n  \"street\": \"Bahnhofstrasse\",\n  \"street_number\": \"42\",\n  \"postal_code\": \"8001\",\n  \"city\": \"Zürich\",\n  \"canton_code\": \"ZH\",\n  \"country\": \"CH\",\n  \"phone\": \"+41 44 123 45 67\",\n  \"is_default\": false,\n  \"is_billing\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/customer/addresses",
              "host": ["{{base_url}}"],
              "path": ["customer", "addresses"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Address created', () => {",
                  "  pm.expect(pm.response.json().data.label).to.eql('Office');",
                  "});",
                  "if (pm.response.json().data) {",
                  "  pm.environment.set('new_address_id', pm.response.json().data._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Address",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Head Office\",\n  \"phone\": \"+41 44 999 88 77\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/customer/addresses/{{new_address_id}}",
              "host": ["{{base_url}}"],
              "path": ["customer", "addresses", "{{new_address_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Updated', () => pm.expect(pm.response.json().data.label).to.eql('Head Office'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Set Default Address",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/addresses/{{new_address_id}}/default",
              "host": ["{{base_url}}"],
              "path": ["customer", "addresses", "{{new_address_id}}", "default"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/addresses/{{new_address_id}}",
              "host": ["{{base_url}}"],
              "path": ["customer", "addresses", "{{new_address_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 204', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
