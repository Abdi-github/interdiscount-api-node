        {
          "name": "Store Top Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{manager_token}}" }],
            "url": {
              "raw": "{{base_url}}/store/analytics/top-products?limit=10&preset=last_30_days",
              "host": ["{{base_url}}"],
              "path": ["store", "analytics", "top-products"],
              "query": [
                { "key": "limit", "value": "10" },
