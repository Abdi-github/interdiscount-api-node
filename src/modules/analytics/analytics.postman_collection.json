        },
        {
          "name": "Top Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/analytics/top-categories?limit=10&preset=last_30_days",
              "host": ["{{base_url}}"],
              "path": ["admin", "analytics", "top-categories"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "preset", "value": "last_30_days" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "User Growth",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/analytics/user-growth?period=monthly&preset=last_6_months",
              "host": ["{{base_url}}"],
              "path": ["admin", "analytics", "user-growth"],
              "query": [
                { "key": "period", "value": "monthly" },
                { "key": "preset", "value": "last_6_months" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Recent Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/analytics/recent-orders?limit=20",
              "host": ["{{base_url}}"],
              "path": ["admin", "analytics", "recent-orders"],
              "query": [{ "key": "limit", "value": "20" }]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        }
      ]
    },
    {
      "name": "Store Analytics",
      "item": [
