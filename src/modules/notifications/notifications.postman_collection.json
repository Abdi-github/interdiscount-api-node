{
  "info": {
    "name": "Notifications Module",
    "description": "Customer in-app notification management: list, unread count, mark read",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4010/api/v1" }
  ],
  "item": [
    {
      "name": "Auth - Login as Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success) {",
              "  pm.environment.set('customer_token', res.data.tokens.access_token);",
              "}",
              "pm.test('Login successful', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer.de@example.ch\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/public/auth/login",
          "host": ["{{base_url}}"],
          "path": ["public", "auth", "login"]
        }
      }
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/notifications?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["customer", "notifications"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "is_read", "value": "", "disabled": true },
                { "key": "type", "value": "", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "if (pm.response.json().data.length > 0) {",
                  "  pm.environment.set('notification_id', pm.response.json().data[0]._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Unread Count",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/notifications/unread-count",
              "host": ["{{base_url}}"],
              "path": ["customer", "notifications", "unread-count"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has count', () => {",
                  "  pm.expect(pm.response.json().data).to.have.property('count');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/notifications/{{notification_id}}/read",
              "host": ["{{base_url}}"],
              "path": ["customer", "notifications", "{{notification_id}}", "read"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customer/notifications/read-all",
              "host": ["{{base_url}}"],
              "path": ["customer", "notifications", "read-all"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
