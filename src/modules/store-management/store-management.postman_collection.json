{
  "info": {
    "name": "Store Management Module",
    "description": "Store manager endpoints: dashboard, inventory, pickup orders, transfers, promotions, store info, and staff. Requires store_manager role and store assignment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4010/api/v1" }
  ],
  "item": [
    {
      "name": "Auth - Login as Store Manager",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success) {",
              "  pm.environment.set('manager_token', res.data.tokens.access_token);",
              "}",
              "pm.test('Login successful', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"manager.de@interdiscount-clone.ch\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/public/auth/login",
          "host": ["{{base_url}}"],
          "path": ["public", "auth", "login"]
        }
      }
    },
    {
      "name": "Store Info",
      "item": [
        {
          "name": "Get My Store Info",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{manager_token}}" }],
            "url": {
              "raw": "{{base_url}}/store/info",
              "host": ["{{base_url}}"],
              "path": ["store", "info"]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has store data', () => {",
            "  pm.expect(pm.response.json().data).to.have.property('name');",
            "  pm.expect(pm.response.json().data).to.have.property('opening_hours');",
            "});"
          ]}}]
        },
        {
          "name": "Update Store Info",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{manager_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+41 44 888 99 00\",\n  \"remarks\": \"Renovated entrance\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/store/info",
              "host": ["{{base_url}}"],
              "path": ["store", "info"]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "List Store Staff",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{manager_token}}" }],
            "url": {
              "raw": "{{base_url}}/store/staff",
              "host": ["{{base_url}}"],
              "path": ["store", "staff"]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
          ]}}]
        }
      ]
    },
